ANTHROPIC_API_KEY=sk-ant-your-key-here

# Wazuh VM — host-only IP (static, always 192.168.56.101)
WAZUH_HOST=192.168.56.101
WAZUH_PORT=55000
WAZUH_USER=wazuh
WAZUH_PASSWORD=wazuh

# SSH tunnel to OpenSearch (port 9200) — default Wazuh OVA credentials
WAZUH_SSH_USER=wazuh-user
WAZUH_SSH_PASSWORD=wazuh
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=WazuhLab123*

# GitHub — push investigation reports to the repo
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=BenjaminB-BlueTeam/soc-home-lab
